Component Builder 2.3
COMPONENT-BUILDER-OPTIONS:
  COMPONENT-MODE:        CTL
  AUTO-UPDATE-FILE-DEFN: true
  SHOW-NODE-NAMES:       false
  DEFAULT-FONT-SIZE:     10

PARAMETERS:
  SECTION: "CONFIGURATION"
    ctrlGrp "Assigned Control Group" "" 0 INTEGER 1 1 54
    Pri     "Priority Level"         "" 0 INTEGER 1 1
  SECTION: "Parameters"
    f   "Switching freq." "" 0 REAL 1000 0 100000
    Rpu "Resistance p.u." "" 0 REAL 0    0 10

GRAPHICS:
  SetColor(YELLOW)
  FilledBox(32,0,288,392)
  SetColor(BLACK)
  Box(32,0,288,392)
  FontSize(10)
  FText(56,32,"wLpu")
  FText(56,64,"wPLL")
  FText(56,96,"ia_ref")
  FText(56,128,"ia_m")
  FText(56,160,"ib_ref")
  FText(56,192,"ib_m")
  FText(56,224,"ic_ref")
  FText(56,256,"ic_m")
  FText(56,288,"vga")
  FText(56,320,"vgb")
  Line(0,32,0,32)
  Line(0,32,0,32)
  Line(0,32,32,32)
  Line(0,64,32,64)
  Line(0,96,32,96)
  Line(0,128,32,128)
  Line(0,160,32,160)
  Line(0,192,32,192)
  Line(0,224,32,224)
  Line(0,256,32,256)
  Line(0,288,32,288)
  Line(0,320,32,320)
  FText(256,64,"VAC_A")
  FText(256,192,"VAC_B")
  FText(256,320,"VAC_C")
  Line(288,64,320,64)
  Line(288,192,320,192)
  Line(288,320,320,320)
  FText(56,352,"vgc")
  Line(0,352,32,352)
  FontSize(10)
  FText(160,200,"Dual Vector")

NODES:
  INITIALIZE_NODE wLpu   = _dud_
  INITIALIZE_NODE wPLL   = _dud_
  INITIALIZE_NODE ia_ref = _dud_
  INITIALIZE_NODE ia_m   = _dud_
  INITIALIZE_NODE ib_ref = _dud_
  INITIALIZE_NODE ib_m   = _dud_
  INITIALIZE_NODE ic_ref = _dud_
  INITIALIZE_NODE ic_m   = _dud_
  INITIALIZE_NODE vga    = _dud_
  INITIALIZE_NODE vgb    = _dud_
  INITIALIZE_NODE VAC_A  = _dud_
  INITIALIZE_NODE VAC_B  = _dud_
  INITIALIZE_NODE VAC_C  = _dud_
  INITIALIZE_NODE vgc    = _dud_

  wLpu 0 1 INPUT REAL
  wPLL 0 2 INPUT REAL
  ia_ref 0 3 INPUT REAL
  ia_m 0 4 INPUT REAL
  ib_ref 0 5 INPUT REAL
  ib_m 0 6 INPUT REAL
  ic_ref 0 7 INPUT REAL
  ic_m 0 8 INPUT REAL
  vga 0 9 INPUT REAL
  vgb 0 10 INPUT REAL
  VAC_A 10 2 OUTPUT REAL
  VAC_B 10 6 OUTPUT REAL
  VAC_C 10 10 OUTPUT REAL
  vgc 0 11 INPUT REAL

VALVE-GROUP:
  RTDS.CTL.RISC_CMODEL
      V4COMP: ModelName = dv SubSystem = $SS Processor = $ctrlGrp Priority = $Pri
      DATA_SIZES: INTDATA=0 FLOATDATA=2 CHARDATA_FRMT=0 INVARS=11 OUTVARS=3
      FLOATDATA: $f f $Rpu Rpu
      INVARS: $wPLL IEEE wPLL $ia_ref IEEE ia_ref $ia_m IEEE ia_m $ib_ref IEEE ib_ref $ib_m IEEE ib_m
      INVARS: $ic_ref IEEE ic_ref $ic_m IEEE ic_m $vga IEEE vga $vgb IEEE vgb $vgc IEEE vgc
      INVARS: $wLpu IEEE wLpu
      OUTVARS: $VAC_A IEEE VAC_A $VAC_B IEEE VAC_B $VAC_C IEEE VAC_C
  END

COMPONENT-DESCRIPTORS:
  CLASSIFICATION: GENERAL
  PHASES:         N/A
  MAINSTEP:       YES
  SUBSTEP:        NO
  SUPERSTEP:      NO
  SMALLDT:        NO
  GPES:           NO
  TWRT:           NO
  DIST:           NO
  DEPRECATED:     NO

